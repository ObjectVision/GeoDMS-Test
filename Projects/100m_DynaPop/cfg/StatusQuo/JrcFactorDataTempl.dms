container JrcFactorDataTempl: IsTemplate = "True", IsHidden = "true"  //, Expr = "ReprojectedFactorData" 
{
	unit<WPoint> domain_grid;
	Container RunRegions;
	parameter<String> BaseYearCorineDataFileName;
		
	container TiffData: IsHidden = "True"
	{
		unit<WPoint> LC2006
			:	DialogData = "Geography/LambertEA"
			,	Source = "JRC:LandCover"
			,	StorageName = "%SourceDataProjDir%/LUISA/landuse/clc06_r_v3.tif"
			,	StorageType = "gdal.grid"
			,	StorageReadOnly = "True"
		{
			attribute<uint8>    GridData;
			attribute<uint8>	ReadData (domain_grid);
			attribute<Classifications/LU/Corine>    CorineLandUse	(domain_grid): Expr = "rlookup(ReadData, classifications/LU/Corine/CLC06_code)";
			attribute<Classifications/LU/ModelType> ModelLandUse 	(domain_grid): Expr = "Classifications/LU/Corine/MT [CorineLandUse]";
			attribute<Classifications/LU/ViewType>  ViewLandUse  	(domain_grid): Expr = "Classifications/LU/Corine/VT2[CorineLandUse]";
		}
		unit<WPoint> LC2012
			:	DialogData = "Geography/LambertEA"
			,	Source = "JRC:LandCover"
			,	StorageName = "%SourceDataProjDir%/LUISA/landuse/LUISA_basemap_2012_080521_100m.tif"
			,	StorageType = "gdal.grid"
			,	StorageReadOnly = "True"
		{
			attribute<uint16> GridData;
			attribute<uint16> ReadData  							(domain_grid);
			attribute<Classifications/LU/Corine>	CorineLandUse	(domain_grid): Expr = "rlookup(ReadData, Classifications/Lu/Corine/BM18_code)";
			attribute<Classifications/LU/ModelType> ModelLandUse 	(domain_grid): Expr = "Classifications/LU/Corine/MT [CorineLandUse]";
			attribute<Classifications/LU/ViewType>  ViewLandUse  	(domain_grid): Expr = "Classifications/LU/Corine/VT2[CorineLandUse]";
		}
		
		unit<WPoint> ghsl1990
			:	DialogData = "Geography/LambertEA"
			,	Source = "GHSL"
			,	StorageName = "%SourceDataProjDir%/LUISA/landuse/ghsl1990_v2018.tif"
			,	StorageType = "gdal.grid"
			,	StorageReadOnly = "True"
		{
			attribute<uint8>    GridData;
			attribute<uint8>    ReadData	(domain_grid);
		}
		unit<WPoint> ghsl2000
			:	DialogData = "Geography/LambertEA"
			,	Source = "GHSL"
			,	StorageName = "%SourceDataProjDir%/LUISA/landuse/ghsl2000_v2018.tif"
			,	StorageType = "gdal.grid"
			,	StorageReadOnly = "True"
		{
			attribute<uint8>    GridData;
			attribute<uint8>    ReadData	(domain_grid);
		}
		unit<WPoint> ghsl2014
			:	DialogData = "Geography/LambertEA"
			,	Source = "GHSL"
			,	StorageName = "%SourceDataProjDir%/LUISA/landuse/ghsl2014_v2018.tif"
			,	StorageType = "gdal.grid"
			,	StorageReadOnly = "True"
		{
			attribute<uint8>    GridData;
			attribute<uint8>    ReadData	(domain_grid);
		}
		unit<WPoint> CorineGrid
			:	DialogData = "Geography/LambertEA"
			,	Source = "JRC:LandCover"
			,	StorageName = "=BaseYearCorineDataFileName"
			,	StorageType = "gdal.grid"
			,	StorageReadOnly = "True"
		{
			attribute<uint16> GridData;
			attribute<uint16> ReadData  							(domain_grid);
			attribute<Classifications/LU/Corine>	CorineLandUse	(domain_grid): Expr = "rlookup(ReadData, Classifications/Lu/Corine/BM18_code)";
			attribute<Classifications/LU/ModelType> ModelLandUse 	(domain_grid): Expr = "Classifications/LU/Corine/MT [CorineLandUse]";
			attribute<Classifications/LU/ViewType>  ViewLandUse  	(domain_grid): Expr = "Classifications/LU/Corine/VT2[CorineLandUse]";
		}
		unit<wpoint> AgeGrid: DialogData = "Geography/LambertEA" , StorageName = "%SourceDataProjDir%/LUISA/landuse/age0.tif", StorageReadOnly = "True"
		{
			attribute<uint8> GridData;
			attribute<uint8> ReadData (domain_grid);
		}
		container AgeFromCLC
		{
			attribute<bool> Is_06_12(domain_grid): Expr = "LC2006/ViewLandUse == LC2012/ViewLandUse";
			attribute<bool> Is_12_18(domain_grid): Expr = "LC2012/ViewLandUse == CorineGrid/ViewLandUse";
			
			attribute<uint8> AgeCLC  (domain_grid): Expr = "Is_12_18 ? Is_06_12 ? uint8(12) : uint8(6) : uint8(0)";
		}
		container X8: StorageName = "='%SourceDataProjDir%/LUISA/succession/X8.tif'", StorageReadOnly = "True"
		{
			attribute<Int16> GridData(Geography/Lambert100mGrid): IsHidden = "True";
			attribute<Int16> ReadData(domain_grid);
		}
		container X9: StorageName = "='%SourceDataProjDir%/LUISA/succession/X9.tif'", StorageReadOnly = "True"
		{
			attribute<Int16> GridData(Geography/Lambert100mGrid): IsHidden = "True";
			attribute<Int16> ReadData(domain_grid);
		}
		Unit<WPoint> Eu27_e: StorageName = "%SourceDataProjDir%/LUISA/Elevation/eu27_e_ha.tif", StorageReadOnly = "True", DialogData = "Geography/LambertEA"
		{
			attribute<units/meter> Elevation (domain_grid): Expr="value(ReadData, units/meter)" ;
			attribute<Int16> GridData: IsHidden = "True";
			attribute<Int16> ReadData(domain_grid);
		}
		
		
		
		//to be phased out eventually with new calibration [JAN 28 2013] :
		container slope_euro: StorageName = "%SourceDataProjDir%/LUISA/Elevation/slope_euro.tif", StorageReadOnly = "True"
		{
			attribute<Int8> GridData(Eu27_e): IsHidden = "True";
			attribute<Int8> ReadData(domain_grid);
		}	
		//to replace slope_euro eventually [Jan 28, 2013]
		Unit<WPoint> slope_continuous: StorageName = "%SourceDataProjDir%/LUISA/Elevation/slope_deg_int16.tif", StorageReadOnly = "True", DialogData = "Geography/LambertEA"
		{
			attribute<Int16> slope (domain_grid): expr="value(ReadData, int16)" ;
			attribute<Int16> GridData (Eu27_e): IsHidden = "True";
			attribute<Int16> ReadData(domain_grid);
		}				
		container sosl_euro: StorageName = "%SourceDataProjDir%/LUISA/Elevation/sosl_euro.tif", StorageReadOnly = "True"
		{
			attribute<Int8> GridData(Eu27_e): IsHidden = "True";
			attribute<Int8> ReadData(domain_grid);
		}	
		Unit<WPoint> aspect_degrees: StorageName = "%SourceDataProjDir%/LUISA/Elevation/aspect_100.tif", StorageReadOnly = "True", DialogData = "Geography/LambertEA"
		{
			attribute<units/degrees> aspect (domain_grid): expr="value(ReadData, units/degrees)" ;
			attribute<Int16> GridData (Eu27_e): IsHidden = "True";
			attribute<Int16> ReadData(domain_grid);
		}	
		unit<wpoint> pop_fe_1:		StorageName = "%SourceDataProjDir%/LUISA/fixed_effects/pv_101116_1.tif", StorageReadOnly = "True", StorageType = "gdal.grid", DialogData = "Geography/LambertEA"
		{
			attribute<float32> GridData;
			attribute<float32> ReadData(domain_grid);
			attribute<float32> fe (domain_grid);
			attribute<int32>   exp: 	expr = "int32(GridData)", StorageName = "%SourceDataProjDir%/LUISA/fixed_effects/pv_101116_1_int32.tif";
		}
		unit<wpoint> pop_fe_1_int32:		StorageName = "%SourceDataProjDir%/LUISA/fixed_effects/pv_101116_1_int32.tif", StorageReadOnly = "True", StorageType = "gdal.grid", DialogData = "Geography/LambertEA"
		{
			attribute<int32> GridData;
			attribute<int32> ReadData(domain_grid);
			attribute<float32> fe (domain_grid): expr = "float32(ReadData)";
		}
		
		unit<wpoint> DistanceToRoads: 
			StorageName       = "%SourceDataProjDir%/LUISA/accessData/m5000dist_to_lvl2to6roads.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<int16> GridData: IsHidden = "True";
			attribute<int16> ReadData(domain_grid);
		}
		unit<wpoint> DistanceToWater:
			StorageName 	  = "%SourceDataProjDir%/LUISA/WaterDist/WaterDist.tif"
			, StorageReadOnly = "True" 
			, DialogData	  = "Geography/LambertEA"
		{
			attribute<float32> GridData: IsHidden = "True";
			attribute<float32> ReadData(domain_grid);
		}
		unit<wpoint> ghspop90:
			StorageName 	  = "%SourceDataProjDir%/LUISA/Population/GHS_250m/EU_HPOP250_1990_ETRS.tif"
			, StorageReadOnly = "True" 
			, DialogData	  = "Geography/LambertEA"
		{
			attribute<float32> GridData: IsHidden = "True";
			attribute<float32> ReadData	(domain_grid);
		}
		unit<wpoint> ghspop15:
			StorageName 	  = "%SourceDataProjDir%/LUISA/Population/GHS_250m/EU_HPOP250_2015_ETRS.tif"
			, StorageReadOnly = "True" 
			, DialogData	  = "Geography/LambertEA"
		{
			attribute<float32> GridData: IsHidden = "True";
			attribute<float32> ReadData	(domain_grid);
		}
		container yield_pre2040
		{
			unit<wpoint> yieldmaize: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/maize_yield_coarse_1100.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldbarley: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/barley_yield_coarse_1100.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldsugbeet: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/sugarbeet_yield_coarse_1100.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldsunflow: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/sunflower_yield_coarse_1100.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldwheat: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/wheat_yield_coarse_1100.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldrapeseed: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/rapeseed_yield_coarse_1100.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
		}
		container yield_post2040
		{
			unit<wpoint> yieldmaize: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/maize_yield_coarse_1110.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldbarley: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/barley_yield_coarse_1110.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldsugbeet: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/sugarbeet_yield_coarse_1110.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldsunflow: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/sunflower_yield_coarse_1110.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldwheat: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/wheat_yield_coarse_1110.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
			unit<wpoint> yieldrapeseed: 	
				StorageName       = "%SourceDataProjDir%/LUISA/Yield_maps/rapeseed_yield_coarse_1110.tif"
				, StorageType = "gdal.grid"
				, StorageReadOnly = "True"
				, DialogData      = "Geography/LambertEA"
			{
				attribute<int32> GridData: IsHidden = "True";
				attribute<int32> ReadData(domain_grid);
			}
		}
		unit<wpoint> AgriAbandon_biophysical: 	
			StorageName       = "%SourceDataProjDir%/LUISA/biophysical/Biophysical_Factors_Final.tif"
			, StorageType = "gdal.grid"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<int16> GridData: IsHidden = "True";
			attribute<int16> ReadData(domain_grid);
		}
		unit<wpoint> Irrigation: 	
			StorageName       = "%SourceDataProjDir%/LUISA/irrigation/AOI_MGM_ITTIG_CULT_FRQ_2000_2016.tif"
			, StorageType = "gdal.grid"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<float32> GridData: IsHidden = "True";
			attribute<float32> ReadData(domain_grid);
		}
		unit<wpoint> RiparianAreas:
			StorageName       = "%SourceDataProjDir%/LUISA/SensitiveAreas/riparianAreas2012.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<units/boolean> riparianAreas(domain_grid): expr = "value(ReadData, units/boolean)" ;
			attribute<uint8> GridData: IsHidden = "True";
			attribute<uint8> ReadData(domain_grid);
		}
		unit<WPoint> erosionRisk: StorageName = "%SourceDataProjDir%/LUISA/SensitiveAreas/erosion_peseta.tif", StorageReadOnly = "True", DialogData = "Geography/LambertEA"
		{
			attribute<units/tonne_ha> erosionRisk(domain_grid): expr = "value(replace_value(ReadData, Int16(-32768), Int16(0 / 0)), units/tonne_ha)" ;
			attribute<Int16> GridData: IsHidden = "True";
			attribute<Int16> ReadData(domain_grid);
		}
		unit<wpoint> FloodRisk:
			StorageName       = "%SourceDataProjDir%/LUISA/SensitiveAreas/FloodRisk_bin.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<units/boolean> FloodRisk (domain_grid): Expr = "value(ReadData,units/boolean)";
			attribute<uint8> GridData: IsHidden = "True";
			attribute<uint8> ReadData(domain_grid);
		}
		
		unit<WPoint> CoastalZone: StorageName = "%SourceDataProjDir%/LUISA/SensitiveAreas/CZ_100m.tif", StorageReadOnly = "True", DialogData = "Geography/LambertEA"
		{
			attribute<units/boolean> Coast (domain_grid): Expr = "value(replace_value(ReadData, Int8(-1), Int8(0 / 0)),units/boolean)";
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
		}	
		
		unit<wpoint> salinity2: StorageName = "%SourceDataProjDir%/LUISA/NECR/salinity.tif", 	StorageType = "tif", DialogData = "Geography/LambertEA"
		{
			attribute<uint8>	GridData: IsHidden = "True";
			attribute<uint8>	ReadData (domain_grid);
		}
			
		unit<WPoint> Natura2000: StorageName = "%SourceDataProjDir%/LUISA/SensitiveAreas/n2k_v2011_bin.tif", StorageReadOnly = "True", 	StorageType = "tif", DialogData = "Geography/LambertEA"
		{
			attribute<units/boolean> Natura2000 (domain_grid): Expr = "value(replace_value(ReadData, Int8(-1), Int8(0 / 0)),units/boolean)";
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
		}
		unit<WPoint> Natura2000Priority: StorageName = "%SourceDataProjDir%/LUISA/SensitiveAreas/Natura2000_End2011_clean_union_Priority_bin.tif", StorageReadOnly = "True", StorageType = "tif", DialogData = "Geography/LambertEA"
		{
			attribute<uint2> Natura2000Priority (domain_grid);
			attribute<uint2> GridData: IsHidden = "True";
			attribute<uint2> ReadData(domain_grid);
		}
		unit<WPoint> NDAs: StorageName = "%SourceDataProjDir%/LUISA/SensitiveAreas/nda_100m_bin.tif", StorageReadOnly = "True", 	StorageType = "tif", DialogData = "Geography/LambertEA"
		{
			attribute<units/boolean> NDA (domain_grid): Expr = "value(replace_value(ReadData, Int8(-1), Int8(0 / 0)),units/boolean)";
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
		}	
		unit<WPoint> NDA_Cat: StorageName = "%SourceDataProjDir%/LUISA/SensitiveAreas/CDDA_v9_clean_unionCat.tif", 	StorageType = "tif", StorageReadOnly = "True", DialogData = "Geography/LambertEA"
		{
			attribute<uint8> NDA_Cat (domain_grid);
			attribute<uint8> GridData: IsHidden = "True";
			attribute<uint8> ReadData(domain_grid);
		}
		unit<wpoint> HNV: 
			StorageName       = "%SourceDataProjDir%/LUISA/SensitiveAreas/HNV/hnv06_100m_v5"
			, StorageType = "gdal.grid"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<units/boolean> IsHNV (domain_grid): Expr = "value(replace_value(ReadData, uint8(-1), uint8(0 / 0)),units/boolean)";
			attribute<uint8> GridData: IsHidden = "True";
			attribute<uint8> ReadData(domain_grid);
		}		
		unit<wpoint> SuitabilityForest: 
			StorageName       = "%SourceDataProjDir%/LUISA/forests/Forest_EU28_100m_8bit.tif"
			, StorageType = "gdal.grid"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<uint8> GridData: IsHidden = "True";
			attribute<uint8> ReadData(domain_grid);
		}		
				
			//NECR DATA
			
		   unit<wpoint> SuitabilityMapNECR:
			//unit<wpoint> NECR_class: nrofrows = 6
			StorageName       = "%SourceDataProjDir%/LUISA/NECR/SuitabilityMapEnergyCrop.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
			
			// This is in case we need to stablish different levels of suitability in the final map
			//attribute<string> Label: DialogType = "LabelText", [ 'zero', 'Very suitable', 'Suitable', 'Moderately suitable', 'Low suitable', 'Very low suitable'];
			//attribute<Float32> SuitValue: [ null, 0, 0.3, 0.3,0.2,0.1,0  ]; 										// I do not why
			//attribute<Bool>    Allowed:   [ false, true, true, true, true, true];	
		}
		
			//attribute<NECR_Class> SuitabilityMapNECR(domain_grid): StorageName = "%SourceDataProjDir%/LUISA/NECR/SuitabilityMapEnergyCrop.tif"; 
		

		unit<wpoint> Peatlands:
			StorageName       = "%SourceDataProjDir%/LUISA/NECR/Peatlands.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<uint2> GridData: IsHidden = "True";
			attribute<uint2> ReadData(domain_grid);
			attribute<uint8>  IsPeatlands(domain_grid): Expr  = "ReadData == 1[uint2] ? uint8(15) : uint8(0)";
			//attribute<uint>  IsPeat(domain_grid): Expr  = "SourceData/IsPeatlands, uint2(15)";
		}
				 	
		unit<uint8> salinityClass: nrofrows = 4
		{
			attribute<string> Label: DialogType = "LabelText", ['zero','Medium', 'Low', 'High' ];
			attribute<uint4>   FileValue: [0, 1, 2, 3];
			attribute<Float32> SuitValue: [null, 15, -15, 35 ]; 											
		}
			attribute<salinityClass> salinity(domain_grid): expr = "TiffData/salinity2/ReadData[salinityClass]"; 
			
						
		unit<uint16> ErodibilityClass: nrofrows= 7
		{
			attribute<string> Label: DialogType = "LabelText", ['zero', 'very low erosion', 'very weak', 'weak', 'Moderate','Strong','very strong' ];
			attribute<uint16>   FileValue: [0, 1, 2, 3, 4, 5, 6];
			attribute<Float32> SuitValue: [null, 0, 0, 0, 10, 20, 25];								

		//	attribute<Bool>    Allowed:   [ false, true, true, true, true, true, true ];		
		}
			attribute<ErodibilityClass> Erodibility(domain_grid): StorageName = "%SourceDataProjDir%/LUISA/NECR/erodibility.tif"; 	
			
				
		unit<wpoint> ContaminatedLands:
             StorageName       = "%SourceDataProjDir%/LUISA/NECR/PotentialContaminatedLand.tif"
             , StorageReadOnly = "True"
             , DialogData      = "Geography/LambertEA"
          {
             attribute<uint8> GridData: IsHidden = "True";
             attribute<uint8> ReadData(domain_grid);
             attribute<uint8> IsContaminated(domain_grid): Expr  = "ReadData == 4[uint8] || ReadData == 5[uint8]  ? uint8(20) : uint8(0)";
            //attribute<uint8> IsContam(domain_grid): Expr  = "IsContaminated ? uint8(20) : uint8(0)";
           }					
	}
	
	container LocSpec_NECR
	{
		attribute<Float32> NECR_LocSpec(domain_grid): Expr = "(TiffData/salinityClass/SuitValue [TiffData/salinity]) + " 
		" (TiffData/ErodibilityClass/SuitValue [TiffData/Erodibility]) + "
		" Float32(TiffData/ContaminatedLands/IsContaminated)";
		
	}
	unit<wpoint> LocSpecSQ: 
			StorageName       = "%SourceDataProjDir%/LUISA/locspecs/locspecSQ_int.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
		}
		unit<wpoint> SQLocSpec_nat01: 
			StorageName       = "%SourceDataProjDir%/LUISA/locspecs/locSp_nat01.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
		}
		unit<wpoint> locspec_integration_agric: 
			StorageName       = "%SourceDataProjDir%/LUISA/locspecs/locspec_integration_agric.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
		}
		unit<wpoint> locspec_integration_pastures: 
			StorageName       = "%SourceDataProjDir%/LUISA/locspecs/locspec_integration_pastures.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
		}
		unit<wpoint> locspec_integration_sv: 
			StorageName       = "%SourceDataProjDir%/LUISA/locspecs/locspec_integration_sv.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
		}
		unit<wpoint> locspec_integration_abandoned: 
			StorageName       = "%SourceDataProjDir%/LUISA/locspecs/locspec_integration_abandoned.tif"
			, StorageReadOnly = "True"
			, DialogData      = "Geography/LambertEA"
		{
			attribute<int8> GridData: IsHidden = "True";
			attribute<int8> ReadData(domain_grid);
		}
		container DGRegio_locspec
		{
			container locspecs_location: expr = "DataPreparation/DGRegio_locspecs";
			
			parameter<uint32> FirstYear:  		expr = "locspecs_location/rules/FirstYear";
			parameter<uint32> LastYear: 		expr = "locspecs_location/rules/LastYear";
			parameter<float32>YearlyIncrease:	expr = "float32(1) / float32(LastYear - FirstYear)";
			
			container cluster_level 
			{
				attribute<uint32>  UrbanClusterId			(domain_grid): expr = "poly2grid(locspecs_location/import/UrbanClusters/Geometry, domain_grid)";
				attribute<uint32>  UrbanForestsZones		(domain_grid): Expr = "poly2grid(locspecs_location/import/UrbanZones/Geometry, domain_grid)";
				attribute<float32> multimodal_transport 	(domain_grid): expr = "MakeDefined((locspecs_location/multimodal_transport_scaled[UrbanClusterId] * locspecs_location/rules/multimodal_effect), float32(0))";
				attribute<float32> urban_regeneration 		(domain_grid): expr = "MakeDefined((locspecs_location/urban_regeneration_scaled[UrbanClusterId] * locspecs_location/rules/urban_regeneration_effect), float32(0))";
				attribute<float32> railway_investments		(domain_grid): expr = "MakeDefined((locspecs_location/railway_investment_scaled[UrbanClusterId] * locspecs_location/rules/railways_effect), float32(0))";
				
				attribute<float32> together					(domain_grid): expr = "multimodal_transport + urban_regeneration + railway_investments";
			}
			container raster_level
			{
				unit<wpoint> airport_industry:	StorageName = "%SourceDataProjDir%/LUISA/PolicyScenarios/Ports_Airports/airports_locspec_industry2.tif", StorageReadOnly = "True", DialogData      = "Geography/LambertEA"
				{attribute<int8> GridData: IsHidden = "True"; attribute<int8> ReadData(domain_grid); attribute<float32> effect (domain_grid): expr = "max_elem((float32(ReadData) / float32(100)) * locspecs_location/rules/airports_effect, float32(0))";}
				unit<wpoint> airport_urban:   	StorageName = "%SourceDataProjDir%/LUISA/PolicyScenarios/Ports_Airports/airports_locspec_urban2.tif", StorageReadOnly = "True", DialogData      = "Geography/LambertEA"
				{attribute<int8> GridData: IsHidden = "True"; attribute<int8> ReadData(domain_grid); attribute<float32> effect (domain_grid): expr = "max_elem((float32(ReadData) / float32(100)) * locspecs_location/rules/airports_effect, float32(0))";}
				unit<wpoint> ports_industry:   	StorageName = "%SourceDataProjDir%/LUISA/PolicyScenarios/Ports_Airports/PORTS_LOCSPEC_INDUSTRY_FINAL1.tif", StorageReadOnly = "True", DialogData      = "Geography/LambertEA"
				{attribute<uint8> GridData: IsHidden = "True"; attribute<uint8> ReadData(domain_grid); attribute<float32> effect (domain_grid): expr = "max_elem((float32(ReadData) / float32(100)) * locspecs_location/rules/ports_effect, float32(0))";}
				
				attribute<bool>    IsFor(domain_grid): Expr = "CaseData/JrcFactorData/TiffData/CorineGrid/ViewLandUse = uint8(6)";
				//(Geography/Lambert100mGrid): Expr = "LandUseData/CLC_100m/LC2006/ReadData = uint8(23) || " 
				//"LandUseData/CLC_100m/LC2006/ReadData = uint8(24) || "
				//"LandUseData/CLC_100m/LC2006/ReadData = uint8(25)"
				//, DisableStorage = "True";		
				attribute<float32>    UrbanForestsLevels 	(domain_grid): Expr = 
					"switch("
						"case(bool(cluster_level/UrbanForestsZones > 0) && !IsFor, float32(2)), "
						"case(bool(cluster_level/UrbanForestsZones > 0) && IsFor, float32(2.3)), "
						"float32(0)"
					")";
				
				unit<wpoint> UrbanForests				
				{attribute<float32> effect (domain_grid): expr = "MakeDefined(float32(1) + (UrbanForestsLevels * locspecs_location/rules/UrbFor_effect), float32(1))";}
				
				attribute<float32> forest_effect 	(domain_grid): expr = "UrbanForests/effect";
				attribute<float32> urban_together 	(domain_grid): expr = "airport_urban/effect";
				attribute<float32> industry_together(domain_grid): expr = "airport_industry/effect + ports_industry/effect";
			}
			
			
			
			attribute<float32> urban_increment   (domain_grid): expr = "float32(1) + cluster_level/together + raster_level/urban_together";
			attribute<float32> industry_increment(domain_grid): expr = "float32(1) + raster_level/industry_together";
			attribute<float32> forests_increment (domain_grid): expr = "raster_level/forest_effect";
		}

	container ShapeData: Expr = "DataPreparation/ShapeData"
	{
		attribute<uint32> Nuts3	(domain_grid): Expr = "RunRegions/RasterSets/Nuts3_LUISA_old"; // issue: these polygons are in AlbersEA projection; requested raster is on LambertEA
		//attribute<uint32> Nuts3	(domain_grid): Expr = "RunRegions/RasterSets/Nuts3_LUISA_old"; // issue: these polygons are in AlbersEA projection; requested raster is on LambertEA
		// FOR TESTING PURPOSES, so far unclear/untested whether this Nuts2 equals TiffData/Nuts2All
		//attribute<UInt16> Nuts2(domain_grid): Expr = "Poly2Grid(/geography/RegionShapes/Nuts2/Polygons, domain_grid, 5)";
		
	}

	attribute<Geography/Lambert100mGrid> Lambert100mGridRel(domain_grid): Expr = "ID(domain_grid)[Geography/Lambert100mGrid]";
	attribute<Geography/Albers1kmGrid> AlbersGridRel       (domain_grid): Expr = "ID(domain_grid)[Geography/Albers1kmGrid]";
