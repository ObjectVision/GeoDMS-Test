		unit<uint32> Nuts1:
			DialogData  = "Polygons",
			DialogType  = "Map",
			expr        = "select_with_org_rel(src/Nuts1/isOrPartOfClueNuts0)"
		{
			attribute<String>   Nuts_code:      expr = "src/Nuts1/Nuts_code[org_rel]";
			attribute<String>   Nuts_label:     expr = "src/Nuts1/Nuts_label[org_rel]";
			attribute<String>   Label:          expr = "Nuts_code + ': ' + Nuts_label", DialogType = "LabelText";
			attribute<LambertEA>Polygons(poly): expr = "src/Nuts1/Polygons[org_rel]";
			attribute<Meter2>   area:           expr = "value(area(Polygons, float64), Meter2)";
			attribute<Regions/Nuts1> RegionId:	expr = "rlookup(Nuts_code, Regions/Nuts1/Name)";
		}
		unit<uint32> Nuts0:
			DialogData  = "Polygons",
			DialogType  = "Map",
			expr        = "select_with_org_rel(src/Nuts0/isOrPartOfClueNuts0)"
		{
			attribute<String>   N0CD:           expr = "src/Nuts0/N0CD[org_rel]";
			attribute<string>	Nuts_code:		expr = "N0CD <> 'LU' ? N0CD: 'BE'";
			attribute<string> 	RunAreaCode:	expr = "switch(case(N0CD = 'LU', 'BE'), case(N0CD = 'BA' || N0CD = 'ME', 'RS'), N0CD)";
			attribute<RunAreas>  RunAreaId:		expr = "rlookup(RunAreaCode, RunAreas/Values)";
			attribute<Regions/Nuts0> RegionId:	expr = "rlookup(Nuts_code, Regions/Nuts0/ICC)";
			attribute<String>   Label:          expr = "N0CD", DialogType = "LabelText";
			attribute<LambertEA>Polygons(poly): expr = "src/Nuts0/Polygons[org_rel]";
			attribute<Meter2>   area:           expr = "value(area(Polygons, float64), Meter2)";
			attribute<string> 	name:			expr = "";
			attribute<String>   Name_econ_ind:  DialogType = "LabelText",
			['fra','aut','belu','apeu','euis','cze','deu','dnk','euba','esp','fin','fra','grc','hun','irl','ita',
			 'aut','euba','belu','euba',null,'euis','nld','pol','prt','apeu','swe',null,'svk','ita','gbr','ita'];
		}
		unit<uint32> RunAreas:
			DialogData = "Polygons",
			DialogType = "map",
			expr 	   = "Unique(Nuts0/RunAreaCode)"
		{
			attribute<LambertEA> Polygons (poly): 	expr = "bp_union_polygon(value(Nuts0/Polygons, ipoint), Nuts0/RunAreaId)[LambertEA]";
			attribute<string>	 Nuts_code:			expr = "Values";
			attribute<String>    N0CD:           	expr = "Values";
			attribute<string> 	 ICC:				expr = "Values";
			attribute<Regions/Nuts0> RegionId:	expr = "rlookup(Nuts_code, Regions/Nuts0/ICC)";
			attribute<String>    Label:          expr = "N0CD", DialogType = "LabelText";
			attribute<Meter2>   area:           expr = "value(area(Polygons, float64), Meter2)";	
		}
		unit<uint32> OutsideEU: 
			DialogData  = "Polygons",
