	container RegionGrids_100m
	{
		/*container NutsDbfTempl: IsTemplate = "True"
		{
			parameter<String> FileName;
			unit<uint32> VAT:
				StorageName     = "='%SourceDataProjDir%/LUISA/nuts2_100m/'+FileName+'.tif.vat.dbf'",
				StorageReadOnly = "True"
			{
				attribute<Regions/Nuts2All> Value;
				attribute<uint32> Count;
				attribute<String> NUTS_CODE;
				attribute<String> ICC;
				attribute<String> SHORT_NAME;
				attribute<String> Label: Expr = "SHORT_NAME", DialogType = "LabelText", DisableStorage = "True";
			}
		}

		container Nuts2a:   Expr = "NutsDbfTempl('nuts2_a')";
		container Nuts2b:   Expr = "NutsDbfTempl('nuts2_b')";
		container Nuts2c:   Expr = "NutsDbfTempl('nuts2_c')";
		container Nuts2d:   Expr = "NutsDbfTempl('nuts2_d')";
		container Canarias: Expr = "NutsDbfTempl('Canarias')";
		
		
		container Nuts2:
			StorageReadOnly = "True",
			StorageName = "%SourceDataProjDir%/LUISA/nuts2_100m/Nuts2All.tif"
		{
			attribute<Regions/Nuts2All> GridData(Lambert100mGrid);
		}

*/
		attribute<Regions/Nuts2All>  Nuts2GridOrg(Lambert100mStripedGrid):
			StorageReadOnly = "True",
			StorageName = "%SourceDataProjDir%/LUISA/nuts2_100m/Nuts2All.tif";
		
		container Tiles
		{
			parameter<UInt16> TileSizeY: [ 1024 ];
			parameter<UInt16> TileSizeX: [ 1024 ];
			parameter<Lambert100mStripedGrid>  JrcTileExtent: Expr = "point_xy(TileSizeX, TileSizeY, Lambert100mStripedGrid)";
			unit<wpoint> TileSetNew:
				Expr  = 
					"range("
						"gridset(Lambert100mStripedGrid, "
							"JrcTileExtent, "
							"point_xy(UInt16(0), UInt16(0), Lambert100mStripedGrid), "
							"wpoint"
						"), "
						"point_xy(UInt16(0), UInt16(0)),"
						"wpoint((BoundRange(Lambert100mStripedGrid) + JrcTileExtent - point_xy(UInt16(1), UInt16(1), Lambert100mStripedGrid)) / JrcTileExtent)"
					")"
			{
				attribute<Lambert100mStripedGrid> LB100_7013:    Expr = "value(ID(.) * JrcTileExtent, Lambert100mStripedGrid)", KeepData = "False"; // COMPATIBILITY ISSUE
				attribute<Lambert100mStripedGrid> LB100_7014:    Expr = "value(ID(.), Lambert100mStripedGrid)", KeepData = "False"; // COMPATIBILITY ISSUE
				attribute<Lambert100mStripedGrid> LB100:    Expr = "=(GeoDmsVersion() < 7.014) ? 'LB100_7013' : 'LB100_7014'", KeepData = "False";
				attribute<Lambert100mStripedGrid> UB100Org: Expr = "LB100 + JrcTileExtent", KeepData = "False";
				attribute<Lambert100mStripedGrid> UB100:    Expr = "point_xy(min_elem(PointCol(UB100Org), PointCol(UpperBound(Lambert100mStripedGrid))),min_elem(PointRow(UB100Org), PointRow(UpperBound(Lambert100mStripedGrid))), Lambert100mStripedGrid)", KeepData = "False";
			}
			attribute<TileSetNew> AggrRel(Lambert100mStripedGrid): Expr = "value((ID(Lambert100mStripedGrid) - LowerBound(Lambert100mStripedGrid)) / JrcTileExtent, TileSetNew)";
			attribute<Bool> HasLandOrg(TileSetNew): Expr = "any(IsDefined(Nuts2GridOrg), AggrRel)", StorageName = "%SourceDataProjDir%/LUISA/data/SelectedTiles.bmp"
			{
				attribute<UInt32> PaletteData(Bool): Expr = "Classifications/Boolean/Palette";
			}

			#include <HasLand.dms>

			unit<uint32> SelectedTiles: Expr = "select_with_org_rel(HasLand)", KeepData = "False"
			{
				attribute<Lambert100mStripedGrid> LB100: Expr = "TileSetNew/LB100[org_rel]";
				attribute<Lambert100mStripedGrid> UB100: Expr = "TileSetNew/UB100[org_rel]";
			}
			unit<wpoint> Lambert100mSelectedTileGrid: Expr = "TiledUnit(SelectedTiles/LB100, SelectedTiles/UB100)";
		}
	}
	container AggrRegions
	{
		
		container km10 
		{
			
			// BEGIN redundant data 
			unit<uint32> poly: storagename = "%SourceDataProjDir%/LUISA/Geography/Grid_LAEA5210_10K_polygons.dbf"
			{
				attribute<LambertEA> Geometry(poly): storagename = "%SourceDataProjDir%/LUISA/Geography/Grid_LAEA5210_10K_polygons.shp";
			}
			// END redundand data
			
// 			parameter<LambertEA> Origin: Expr = "point_xy(1500000.0,  900000.0, LambertEA)"; // Left-Bottom coord
// 			parameter<LambertEA> Extent: Expr = "point_xy(6000000.0, 4530000.0, LambertEA)";
			parameter<LambertEA> Origin: Expr = "point_xy(      0.0,  700000.0, LambertEA)"; // Left-Bottom coord
			parameter<LambertEA> Extent: Expr = "point_xy(8400000.0, 6700000.0, LambertEA)";
			
			parameter<LambertEA> LeftTop:    Expr = "point_xy(pointcol(Origin), pointrow(Origin)+pointrow(Extent), LambertEA)";
			unit<wpoint> grid:
				Expr  =
					"range("
						"gridset(LambertEA, "
							"point_xy(10000.0, -10000.0, LambertEA), "
							"LeftTop, "
							"wpoint"
						"), "
						"point_xy(UInt16(0),UInt16(0)),"
						"wpoint(Extent  / point_xy(10000.0, 10000.0, LambertEA))"
					")";
		}
	}
	#include<CapriLookup.dms>
}
