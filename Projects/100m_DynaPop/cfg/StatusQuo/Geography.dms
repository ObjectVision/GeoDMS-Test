	{
		container src: isHidden = "True" // Original nuts shapefile, including not modelled regions
		{	
			unit<uint32> composite_LAU:
				DialogData      = "Polygons",
				DialogType      = "Map",
				StorageName     = "%sourceDataProjDir%/Geography/nuts_Lambert/LAU_2.dbf",
				StorageReadOnly = "True"
