		unit<uint32> composite_LAU:
			DialogData  = "Polygons",
			DialogType  = "Map",
			expr        = "select_with_org_rel(src/composite_LAU/isOrPartOfClueNuts0)"
		{
			attribute<String>   Nuts_code:      expr = "src/composite_LAU/LAU_code[org_rel]";
			attribute<LambertEA>Polygons(poly): expr = "src/composite_LAU/Polygons[org_rel]";
			attribute<LambertEA>point:			expr = "src/composite_LAU/point[org_rel]";
			attribute<Meter2>   area:           expr = "value(area(Polygons, float64), Meter2)";
			attribute<Regions/Nuts2> Nuts2Id: 	expr = "Nuts2/Nuts2Id[point_in_polygon(point, Nuts2/Polygons)]";
		}
		unit<uint32> Nuts3:
			DialogData  = "Polygons",
			DialogType  = "Map",
			expr        = "select_with_org_rel(src/Nuts3/isOrPartOfClueNuts0)"
		{
			attribute<String>   Nuts_code:      expr = "src/Nuts3/Nuts_code[org_rel]";
			attribute<String>   N2CD:           expr = "substr(Nuts_code, 0, 4)";
			attribute<String>   N1CD:           expr = "substr(Nuts_code, 0, 3)";
			attribute<String>   N0CD:           expr = "substr(Nuts_code, 0, 2)";
			attribute<Regions/Nuts2> Nuts2_rel: expr = "rlookup(N2CD, Regions/Nuts2/code)";
			attribute<Regions/Nuts1> Nuts1_rel: expr = "rlookup(N1CD, Regions/Nuts1/name)";
			attribute<Regions/Nuts0> Nuts0_rel: expr = "rlookup(N0CD, Regions/Nuts0/ICC )";
			
			attribute<String>   Nuts_label:     expr = "src/Nuts3/Nuts_label[org_rel]";
			attribute<String>   Label:          expr = "Nuts_code + ': ' + Nuts_label", DialogType = "LabelText";
			attribute<LambertEA>Polygons(poly): expr = "src/Nuts3/Polygons[org_rel]";
			attribute<LambertEA>point:			expr = "src/Nuts3/point[org_rel]";
			attribute<Meter2>   area:           expr = "value(area(Polygons, float64), Meter2)";
			attribute<Regions/Nuts2> Nuts2Id: 	expr = "Nuts2/Nuts2Id[point_in_polygon(point, Nuts2/Polygons)]";
		}
		unit<uint32> Nuts2:
			DialogData  = "Polygons",
			DialogType  = "Map",
			expr        = "select_with_org_rel(src/Nuts2/isOrPartOfClueNuts0)"
		{
			attribute<String>   Nuts_code:         expr = "src/Nuts2/Nuts_code[org_rel]";
			attribute<String>   Nuts_label:        expr = "src/Nuts2/Nuts_label[org_rel]";
			attribute<String>   Label:             expr = "Nuts_code + ': ' + Nuts_label", DialogType = "LabelText";
			attribute<LambertEA>Polygons(poly):    expr = "src/Nuts2/Polygons[org_rel]";
			attribute<Meter2>   area:              expr = "value(area(Polygons, float64), Meter2)";
			attribute<Regions/Nuts2> Nuts2Id:      expr = "rlookup(Nuts_code, Regions/Nuts2/Code)";
			attribute<Regions/Nuts2> RegionId:     expr = "Nuts2Id";
			attribute<string>	ICC:			   expr = "src/Nuts2/ICC[org_rel]";
//			attribute<string>	Merge:         expr = "src/Nuts2/Merge[org_rel]";
			attribute<Nuts2_Merged>	MergedZonesId: expr  = "point_in_polygon(centroid_or_mid(Polygons), Nuts2_merged/Polygons)";
		}
	
		unit<uint32> Nuts2_merged:
			DialogData  = "Polygons",
