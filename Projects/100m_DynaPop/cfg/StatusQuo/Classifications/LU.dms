container LU
{	
	unit<UInt8> ModelType: NrOfRows = 20 // @USERINPUT: keep in sync with the actual nr of model classes
	{
		parameter<uint32> nrAttr: Expr = "10";
		unit<UInt32> Elements: Expr = "Range(uint32, 0, nrAttr*#ModelType)"
		{
			attribute<String> Text: [ // @USERINPUT
			//   VT,  IT,    R,    G,    B,  Label,                  	abandoned_version	Demandcharacteristics, 	MinClaimColumn, 	MaxClaimColumn
				'1' , '0','219','000','000','Urban',                   	'AbanUrban',			'urban',    		 	'minUrban',     			'maxUrban',
				'2' , '1','128','000','128','Industrial',              	'AbanIndustry',			'industrial', 			'IndustryMin',   			'IndustryMax',
				'3' , '5','254','250','194','ArableCrops',        	    'AbanArable',			'agrimarket',   		'ArableMin', 				'ArableMax',
				'4' , '6','255','230','077','MixedCropLivestock',      	'AbanArable',			'agrimarket',    		'MixMin',   				'MixMax',
				'5' , '7','163','222','133','LivestockProduction',     	'AbanPastures',			'agrimarket',    		'PastureMin',    			'PastureMax',
				'6' , '2','001','099','000','ForestsMature',            null,					'forest',				'ForestsMatMin',    		'ForestsMatMax', 
				'7' , '3','114','137','068','TransWoodlandShrub',    	null,					null, 					null, 						null, 	
				'8' , '8','230','128','000','Vineyards',            	'AbanPermanentCrops',	'agrimarket',    		'VineMin',	    			'VineMax',
				'9' , '8','242','166','077','FruitProduction',          'AbanPermanentCrops',	'agrimarket',    		'FruitMin',      			'FruitMax',
				'10', '8','230','166','000','OliveProduction',         	'AbanPermanentCrops',	'agrimarket',    		'OlivMin',  				'OlivMax',
				'11', '4','216','213','164','AbanArable',         		null,					'abandoned_agri',		'min_AbanArable', 			'max_AbanArable', // 'Capri',    'AbandonedArable',         null,
				'12', '4','153','130','120','AbanPermanentCrops', 		null,					'abandoned_agri',		'min_AbanPermanentCrops',  	'max_AbanPermanentCrops', // 'Capri',    'AbandonedPermanentCrops', null,
				'13', '4','137','170','125','AbanPastures',       		null,					'abandoned_agri',		'min_AbanPastures',  		'max_AbanPastures', // 'Capri',    'AbandonedPastures',       null,
				'14', '0','160','000','000','AbanUrban',          		null,					'abandoned_urban',		'min_AbanUrban',			'max_AbanUrban', // amount is determined by maximal amount of abandonable urban.
				'15', '1','071','000','117','AbanIndustry',        		null,					null, 					null, 						null,  // amount is determined by decreased demand for Industry with low transition costs to Abandonment.
				'16', '8','000','200','000','BioEnergyCrops' ,         	'AbanPermanentCrops',	'agrimarket',    		'EnergMin',     			'EnergyMax',
				'17', '3','166','242','000','SHVA',    					null,					null, 					null, 						null,
				'18', '2','036','130','056','ForestsYoung',            	null,					'forest',  				'ForestsYoMin',    			'ForestsYoMax',
				'19', '7','211','255','190','NaturalGrassland',			null,					null, 					null, 						null,			
				'20', '5','230','230','230','RiceProduction',         	'AbanArable',			'agrimarket',   		'RiceMin',  				'RiceMax'
				
			];
		}

		attribute<String>           Name: Expr = "Label";
		attribute<ViewType>           VT: Expr =" value(Elements/Text[value(UInt32(ID(.))* nrAttr + 0, Elements)], ViewType)";
		attribute<IndicatorType>      IT: Expr =" value(Elements/Text[value(UInt32(ID(.))* nrAttr + 1, Elements)], IndicatorType)";
		attribute<UInt8>               R: Expr =" UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 2, Elements)])";
		attribute<UInt8>               G: Expr =" UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 3, Elements)])";
		attribute<UInt8>               B: Expr =" UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 4, Elements)])";
		attribute<String>          Label: Expr ="       Elements/Text[value(UInt32(ID(.))* nrAttr + 5, Elements)]" , DialogType = "LabelText";
		attribute<uint32>          Color: Expr ="rgb(R,G,B)", DialogType = "BrushColor";
		
		attribute<string> Abandoned_Use:			Expr ="Elements/Text[value(UInt32(ID(.))* nrAttr + 6, Elements)]";
		attribute<String> DemandCharacteristics:  	Expr ="Elements/Text[value(UInt32(ID(.))* nrAttr + 7, Elements)]";
		attribute<String> MinClaimColumn: 			Expr ="Elements/Text[value(UInt32(ID(.))* nrAttr + 8, Elements)]";
		attribute<String> MaxClaimColumn: 			Expr ="Elements/Text[value(UInt32(ID(.))* nrAttr + 9, Elements)]";
		
		attribute<bool>   DynamicDemand:			Expr = "!IsNull(DemandCharacteristicsRel) && MetaData/DemandCharacteristics/Dynamic[DemandCharacteristicsRel]";
		attribute<bool>   Change:					Expr = "!IsNull(DemandCharacteristicsRel) && MetaData/DemandCharacteristics/Change[DemandCharacteristicsRel]";
		
		attribute<.>	  Abandoned_MT:				Expr = "rlookup(Abandoned_Use, Name)";
		
		// value enumeration
		parameter<.> Urban:                   expr = "value( 0, .)";
		parameter<.> Industrial:              expr = "value( 1, .)";
		parameter<.> ArableCrops:             expr = "value( 2, .)";
		parameter<.> MixedCropLivestock:      expr = "value( 3, .)";
		parameter<.> LivestockProduction:     expr = "value( 4, .)";
		parameter<.> ForestsMature:           expr = "value( 5, .)";
		parameter<.> TransWoodlandShrub:   	  expr = "value( 6, .)";
		parameter<.> Vineyards:               expr = "value( 7, .)";
		parameter<.> FruitProduction:         expr = "value( 8, .)";
		parameter<.> OliveProduction:         expr = "value( 9, .)";
		parameter<.> AbanArable:         	  expr = "value(10, .)";
		parameter<.> AbanPermanentCrops: 	  expr = "value(11, .)";
		parameter<.> AbanPastures:       	  expr = "value(12, .)";
		parameter<.> AbanUrban:           	  expr = "value(13, .)";		
		parameter<.> AbanIndustry:            expr = "value(14, .)";
		parameter<.> BioEnergyCrops:          expr = "value(15, .)";
		parameter<.> SHVA:					  expr = "value(16, .)";
		parameter<.> ForestsYoung:			  expr = "value(17, .)";
		parameter<.> NaturalGrassland:		  expr = "value(18, .)";
		parameter<.> RiceProduction:		  expr = "value(19, .)";		
		attribute<bool> IsBuiltupArea:        expr = "ID(.) == Urban || ID(.) == Industrial || ID(.) == AbanUrban || ID(.) == AbanIndustry";
		attribute<bool> IsUrban:              expr = "ID(.) == Urban";
		attribute<bool> IsIndustrial:         expr = "ID(.) == Industrial";
		attribute<bool>	IsAgriCultural:	 	  expr = "ID(.) == ArableCrops || ID(.) == MixedCropLivestock || ID(.) == LivestockProduction || ID(.) == Vineyards  || ID(.) == FruitProduction || ID(.) == OliveProduction || ID(.) == BioEnergyCrops || ID(.) == RiceProduction";
		attribute<bool> IsForest:         	  expr = "ID(.) == ForestsMature || ID(.) == ForestsYoung";
		attribute<bool> IsAbandoned:          expr = "ID(.) == AbanArable || ID(.) == AbanPermanentCrops || ID(.) == AbanPastures || ID(.) == AbanUrban || ID(.) == AbanIndustry";
		attribute<bool> IsAbandonedUrban:	  expr = "ID(.) == AbanUrban";
		attribute<bool>	IsArableRotation:	  expr = "ID(.) == ArableCrops";
		attribute<bool>	IsMixedRotation:	  expr = "ID(.) == MixedCropLivestock";
		attribute<bool> IsArableType:		  expr = "ID(.) == ArableCrops 	|| ID(.) == MixedCropLivestock 	|| ID(.) == RiceProduction";
		attribute<bool> IsPermanentType:	  expr = "ID(.) == Vineyards 	|| ID(.) == FruitProduction 	|| ID(.) == OliveProduction || ID(.) == BioEnergyCrops";
		attribute<bool> IsPasturesType:		  expr = "ID(.) == LivestockProduction";	
		attribute<bool> IsAbanArable:		  expr = "ID(.) == AbanArable";
		attribute<bool> IsAbanPermanentCrops:	  expr = "ID(.) == AbanPermanentCrops";
		attribute<bool> IsAbanPastures:		  expr = "ID(.) == AbanPastures";
		
		attribute<MetaData/DemandCharacteristics> DemandCharacteristicsRel: expr = "rlookup(DemandCharacteristics, MetaData/DemandCharacteristics/Name)";
		
	}
	unit<UInt32> ModelMatr: Expr = "Combine(ModelType, ModelType)";
	
	unit<UInt8> ViewType: Expr = "Range(UInt8, UInt8(0), UInt8(26))"
	{
		parameter<uint32> nrAttr: Expr = "7";
		unit<UInt32> Elements: Expr = "Range(uint32, 0, nrAttr*#ViewType)"
		{
			attribute<String> Text: [
			//   R,    G,    B,   IsNaturalArea, GridImpedance, Label,
			//                                   [min/cell]
			// Model Types
				'255','255','255','false','0.4', 'None', 				'0',
				'219','000','000','false','0.4', 'Urban', 				'1',
				'128','000','128','false','0.4', 'Industrial',			'2',
				'254','250','194','false','0.4', 'ArableCrops',			'3',
				'255','230','077','false','0.4', 'MixedCropLivestock',	'3',
				'163','222','133','false','0.4', 'LivestockProduction',	'3',
				'001','099','000','true' ,'1.0', 'ForestsMature',		'5',
				'114','137','068','true' ,'0.4', 'TransWoodlandShrub',  '6',
				'230','128','000','false','0.4', 'Vineyards',			'4',
				'242','166','077','false','0.4', 'FruitProduction',		'4',
				'230','166','000','false','0.4', 'OliveProduction',		'4',
				'216','213','164','false','0.4', 'AbanArable',			'3',
				'153','130','120','false','0.4', 'AbanPermanentCrops',	'4',
				'137','170','125','false','0.4', 'AbanPastures',		'3',
				'160','000','000','false','0.4', 'AbanUrban',			'1',
				'071','000','117','false','0.4', 'AbanIndustry',		'2',
				'080','200','050','false','0.9', 'BioEnergyCrops',		'3',
				'166','242','000','true' ,'0.4', 'SHVA',				'6',
				'001','099','000','true' ,'1.0', 'ForestsYoung',		'5',
				'211','255','190','true' ,'0.4', 'NaturalGrassland',	'6',
				'230','230','230','false','0.4', 'RiceProduction',		'3',
			// Exogenous Types
				'064','064','064','false','0.4', 'Infrastructure',  	'8',
				'192','192','192','true' ,'1.0', 'OtherNature',			'6',
				'100','100','254','true' ,'6.0', 'Wetlands',			'6',
				'128','242','230','false','6.0', 'WaterBodies',			'9',
				'173','254','47', 'true' ,'0.4', 'UrbanGreenLeisure',	'7'
			];
		}
		attribute<String>  Name:                                    Expr = "Label";
		attribute<UInt8>      R:                                    Expr = " UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 0, Elements)])";
		attribute<UInt8>      G:                                    Expr = " UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 1, Elements)])";
		attribute<UInt8>      B:                                    Expr = " UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 2, Elements)])";
		attribute<Bool>IsNatural:                                   Expr = " Bool (Elements/Text[value(UInt32(ID(.))* nrAttr + 3, Elements)])";
		attribute<bool>IsAgricultural:								Expr = "(id(.) > uint8(2) && id(.) < uint8(6)) || (id(.) > uint8(7) && id(.) < uint8(11)) || id(.) = uint8(16) || id(.) = uint8(20)";
		attribute<bool>IsPossiblyAgriAbandoned:						Expr = "(id(.) > uint8(10) && id(.) < uint8(14)) || id(.) = uint8(7) || id(.) = uint8(17)";
		attribute<units/min> GridImpedance: 						Expr = "(Elements/Text[value(UInt32(ID(.))* nrAttr + 4, Elements)])[units/min]";

		attribute<String> Label: 									Expr = "Elements/Text[value(UInt32(ID(.))* nrAttr + 5, Elements)]", DialogType = "LabelText";
		attribute<SimpleViewType> svt_id: 							Expr = "uint8(Elements/Text[value(UInt32(ID(.))* nrAttr + 6, Elements)])[SimpleViewType]";
		attribute<uint32> Color: Expr ="rgb(R,G,B)", DialogType = "BrushColor";		
		
		// value enumeration
		parameter<.> Infrastructure:	   expr = "value(#ModelType + 1, .)";
		parameter<.> OtherNature:  		   expr = "value(#ModelType + 2, .)";
		parameter<.> Wetlands:     		   expr = "value(#ModelType + 3, .)";
		parameter<.> WaterBodies:   	   expr = "value(#ModelType + 4, .)";
		parameter<.> UrbanGreenLeisure:    expr = "value(#ModelType + 5, .)";		
		
		
		// derived relations
		attribute<ModelType>     MT: Expr = "invert(ModelType/VT)";
		attribute<IndicatorType> IT: Expr = "lookup(MT, ModelType/IT)";
		attribute<Bool>          IsBuiltupArea: Expr = "lookup(MT, ModelType/IsBuiltupArea)";
		
	}
	unit<uint8> SimpleViewType: NrOfRows = 10 {
	
		parameter<uint32> nrAttr: Expr = "5";
		unit<UInt32> Elements: Expr = "Range(uint32, 0, nrAttr*#ViewType)"
		{
			attribute<String> Text: [
			'0',	'Nodata',			'254',	'254',	'254',
			'1',	'Urban',			'219',	'0',	'0',
			'2',	'Industrial',		'128',	'0',	'128',
			'3',	'Agriculture',		'254',	'250',	'194',
			'4',	'PermanentCrops',	'230',	'128',	'0',
			'5',	'Forests',			'1',	'99',	'0',
			'6',	'OtherNature',		'211',	'255',	'190',
			'7',	'UrbanGreen',		'173',	'254',	'47',
			'8',	'Infrastructure',	'128',	'128',	'128',
			'9',	'Water',			'128',	'242',	'230'];
		}
		attribute<UInt8>      R: Expr = " UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 2, Elements)])";
		attribute<UInt8>      G: Expr = " UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 3, Elements)])";
		attribute<UInt8>      B: Expr = " UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 4, Elements)])";
		attribute<String> Label: Expr = "Elements/Text[value(UInt32(ID(.))* nrAttr+1, Elements)]" , DialogType = "LabelText";
		attribute<uint32> Color: Expr ="rgb(R,G,B)", DialogType = "BrushColor";		
	}
	
	unit<UInt8> IndicatorType: NrOfRows = 11
	{
		parameter<uint32> nrAttr: Expr = "5";
		unit<UInt32> Elements: Expr = "Range(uint32, 0, nrAttr*#ViewType)"
		{
			attribute<String> Text: [
			//	R,    G,    B,    isAgriculture, Label,
				'219','000','000','False',       'Urban',
				'128','000','128','False',       'Industrial',
				'001','099','000','False',       'Forest',
				'114','137','068','False',       'SemiNatural',
				'153','130','120','False',       'AbanAgriCulture',
				'254','250','194','True',        'ArableFarming',
				'255','230','077','True',        'MixedAgriculture',
				'163','222','133','True',        'LivestockGrazing',				
				'230','128','000','True',        'PermanentCrops',
				'160','000','000','False',       'AbanUrban',
				'071','000','117','False',       'AbanIndustry'];
		}
		attribute<String>         Name: Expr = "Label";
		attribute<UInt8>             R: Expr = " UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 0, Elements)])";
		attribute<UInt8>             G: Expr = " UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 1, Elements)])";
		attribute<UInt8>             B: Expr = " UInt8(Elements/Text[value(UInt32(ID(.))* nrAttr + 2, Elements)])";
		attribute<bool>  isAgriculture: Expr = "  Bool(Elements/Text[value(UInt32(ID(.))* nrAttr + 3, Elements)])";
		attribute<String>        Label: Expr = "       Elements/Text[value(UInt32(ID(.))* nrAttr + 4, Elements)]" , DialogType = "LabelText";
		attribute<bool> isUrban:        Expr = "Label = 'Urban'";
		attribute<bool> isSemiNatural:  Expr = "Label = 'SemiNatural'";
		attribute<bool> isForest:       Expr = "Label = 'Forest'";
		attribute<bool>	isIndustrial:   Expr = "Label = 'Industrial'";
		attribute<uint32>        Color: Expr ="rgb(R,G,B)", DialogType = "BrushColor";
		
		parameter<.> Urban:                 expr = "value(0, .)";
		parameter<.> Industrial:            expr = "value(1, .)";
		parameter<.> Forest:                expr = "value(2, .)";
		parameter<.> SemiNatural:           expr = "value(3, .)";
		parameter<.> AbanAgriCulture: 		expr = "value(4, .)";
		parameter<.> ArableFarming:         expr = "value(5, .)";
		parameter<.> MixedAgriculture:      expr = "value(6, .)";
		parameter<.> LivestockGrazing:      expr = "value(7, .)";
		parameter<.> PermanentCrops:        expr = "value(8, .)";				
		parameter<.> AbanUrban:       		expr = "value(7, .)";
		parameter<.> AbanIndustry:    		expr = "value(8, .)";
	}
	unit<uint8> change_06_12: NrOfRows = 44
	{
		attribute<uint8> value: expr = "id(.) + uint8(1)";
		attribute<uint16> CLC_Val: [121,133,142,231,111,112,122,124,131,132,141,212,243,311,321,322,324,332,411,512,123,211,213,221,222,242,312,313,331,333,412,421,223,511,523,323,334,521,241,522,244,422,423,335];

	}
	
	
