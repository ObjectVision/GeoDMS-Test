		attribute<ModelType> MT:        Expr = "value(Elements/Text[value(UInt32(ID(.))*13+3, Elements)], ModelType)";
		attribute<ViewType>  VT:        Expr = "value(Elements/Text[value(UInt32(ID(.))*13+4, Elements)], ViewType)";
		attribute<ViewType>  VT2:       Expr = "MakeDefined(ModelType/VT[MT], VT)";
		
		
		attribute<UInt32> R: Expr = "uint32(Elements/Text[value(UInt32(ID(.))*13+5, Elements)])";
		attribute<UInt32> G: Expr = "uint32(Elements/Text[value(UInt32(ID(.))*13+6, Elements)])";
		attribute<UInt32> B: Expr = "uint32(Elements/Text[value(UInt32(ID(.))*13+7, Elements)])";
		attribute<UInt32> BrushColor: Expr = "((B*256)+G)*256+R", DialogType = "BrushColor";

//		attribute<Corine> nrClc:      Expr = "invert(Corine/Grid_Code)";
		attribute<String> Label1:     Expr = "Elements/Text[value(UInt32(ID(.))*13+8, Elements)]";
		attribute<String> Label2:     Expr = "Elements/Text[value(UInt32(ID(.))*13+9, Elements)]";
		attribute<String> Label:      Expr = "Elements/Text[value(UInt32(ID(.))*13+10, Elements)]", DialogType = "LabelText";
		
		attribute<PopulatedLandUseTypes> 	PopulatedLandUseType: 	Expr = "rlookup(uint32(Elements/Text[value(UInt32(ID(.))*13+11, Elements)]), PopulatedLandUseTypes/Lookup)";
		attribute<bool> 					Water:					Expr = "bool(value(Elements/Text[value(UInt32(ID(.))*13+12, Elements)], uint32))";
		attribute<bool>						Burnt:					Expr = "id(.) = uint8(334)";
		
		attribute<string> name := asItemName(label); 
		container V := for_each_nedv(name, string(id(.))+'[..]', void, .);
		
		
