	unit<uint32> SpeedStats := range(uint32, 0, 33)
	{
		attribute<string>  Name            := string(Matrix/Values[((id(.) * NrAttributes)+0)[Matrix]]);
		attribute<string>  RoadClass       := string(Matrix/Values[((id(.) * NrAttributes)+1)[Matrix]]);
		attribute<string>  OSM_Surface     := string(Matrix/Values[((id(.) * NrAttributes)+2)[Matrix]]);
		attribute<uint32>  Frequency       := uint32(Matrix/Values[((id(.) * NrAttributes)+3)[Matrix]]);
		attribute<km_hr>   Mean_Speed      := Matrix/Values[((id(.) * NrAttributes)+4)[Matrix]][km_hr];
		
		parameter<km_hr>   Connector_Speed := Sum(Mean_Speed * float64(Name = 'tertiary_x_')) / 1.2d; //@CJ 220331 wat is deze 1.2?
		
		//matrix below: speed estimates from OSM depending on road class and road surface
		//averaged from OSM observations by Konstantin Rosina, Fall 2018
		unit<uint32> Matrix := range(uint32, 0, #SpeedStats * NrAttributes)
		{
			attribute<string> Values: [
			//'id',						'road_class',		surface',	'frequency','mean_speed',
			'motorway_x_',				'motorway',			'',			'3476',		'105.149597238',
			'motorway_x_asphalt',		'motorway',			'asphalt',	'5787',		'104.644893727',
