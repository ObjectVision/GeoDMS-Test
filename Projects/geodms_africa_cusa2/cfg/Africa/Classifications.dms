	unit<uint8> OSM_Countries: NrOfRows = 55
	{
		unit<UInt32> Elements := range(uint32, 0, nrAttr * #.)
		{
			attribute<String> Text: [
			// Name                                        ,Use
			 'Algeria'                                     , '',
			 'Angola'                                      , '',
			 'Benin'                                       , '',
			 'Botswana'                                    , '',
			 'Burkina Faso'                                , 'TRUE',
			 'Burundi'                                     , '',
			 'Cameroon'                                    , '',
			 'Canary Islands'                              , '',
			 'Cape Verde'                                  , '',
			 'Central African Republic'                    , '',
			 'Chad'                                        , '',
			 'Comores'                                     , '',
			 'Congo Brazzaville'                           , '',
			 'Congo Democratic Republic'                   , '',
			 'Djibouti'                                    , '',
			 'Egypt'                                       , '',
			 'Equatorial Guinea'                           , '',
			 'Eritrea'                                     , '',
			 'Ethiopia'                                    , '',
			 'Gabon'                                       , '',
			 'Ghana'                                       , '',
			 'Guinea'                                      , '',
			 'Guinea-Bissau'                               , '',
			 'Ivory Coast'                                 , 'TRUE',
			 'Kenya'                                       , '',
			 'Lesotho'                                     , '',
			 'Liberia'                                     , '',
			 'Libya'                                       , '',
			 'Madagascar'                                  , '',
			 'Malawi'                                      , '',
			 'Mali'                                        , '',
			 'Mauritania'                                  , '',
			 'Mauritius'                                   , '',
			 'Morocco'                                     , '',
			 'Mozambique'                                  , '',
			 'Namibia'                                     , '',
			 'Niger'                                       , '',
			 'Nigeria'                                     , '',
			 'Rwanda'                                      , '',
			 'Saint Helena Ascension and Tristan da Cunha' , '',
			 'Sao Tome and Principe'                       , '',
			 'Senegal and Gambia'                          , '',
			 'Seychelles'                                  , '',
			 'Sierra Leone'                                , '',
			 'Somalia'                                     , '',
			 'South Africa'                                , '',
			 'South Sudan'                                 , '',
			 'Sudan'                                       , '',
			 'Swaziland'                                   , '',
			 'Tanzania'                                    , '',
			 'Togo'                                        , '',
			 'Tunisia'                                     , '',
			 'Uganda'                                      , '',
			 'Zambia'                                      , '',
			 'Zimbabwe'                                    , ''
			];
		}
		
	
		attribute<string> label := Elements/Text[value(uInt32(id(.))* nrAttr + 0, Elements)];
		attribute<string> Use        := Elements/Text[value(uInt32(id(.))* nrAttr + 1, Elements)];
		attribute<bool>   IsToBeUsed := bool(Use);
		attribute<string> name  := AsItemName(label);
		attribute<string> path_name  := replace(label, ' ', '-');
		
		attribute<string> path  := '%CUSA2_DataDir%/OSM/20230111/'+path_name+'-latest-free.shp/gis_osm_roads_free_1';
		
		parameter<uint32> nrAttr := 2;
		
		unit<uint8> sub := select_with_attr_by_cond(., IsToBeUsed);
	}
	
	
	
	unit<uint8> Services : = range(uint8, 0b, 2b)
	{
		attribute<string>            Name           := string(Matrix/Values[((id(.) * NrAttributes)+0b)[Matrix]]);
		attribute<string>            Label          := string(Matrix/Values[((id(.) * NrAttributes)+1b)[Matrix]]);
		
		unit<uint8> Matrix: = range(uint8, 0b, uint8(#.) * NrAttributes)
		{
			attribute<string> Values: 
			[
				'Edu',    'Education',
				'Health', 'Healthcenters'
			];
		}
	
		parameter<uint8> NrAttributes: = 2b;
	}
	
