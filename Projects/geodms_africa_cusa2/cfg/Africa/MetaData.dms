	Container Wij
	{
		unit<SPoint> AccessInterpolation := range(spoint, point_yx(-11s, -11s), point_yx(12s, 12s)) 
		{
			attribute<UInt32>  Dist2 := Dist2(point_yx(0s, 0s, .), uint32);
			attribute<float32> Attr  := Dist2 > 0 && Dist2 < 12*12 ? float32(Dist2)^-1f : 0f;
		}
	}
