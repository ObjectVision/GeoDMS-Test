			'floodsCorridorId7',    'polyshp',      '%CUSA2_DataDir%/CorridorsFloods/floodscorridorId7'             ,'shp',
			'floodsCorridorId8',    'polyshp',      '%CUSA2_DataDir%/CorridorsFloods/floodscorridorId8'             ,'shp',
			'floodsCorridorId9',    'polyshp',      '%CUSA2_DataDir%/CorridorsFloods/floodscorridorId9'             ,'shp',
			'floodsCorridorId10',   'polyshp',      '%CUSA2_DataDir%/CorridorsFloods/floodscorridorId10'            ,'shp',
			'floodsCorridorId11',   'polyshp',      '%CUSA2_DataDir%/CorridorsFloods/floodscorridorId11'            ,'shp',
			'Africa_countries_AEA', 'polyshp',      '%CUSA2_DataDir%/boundaries/GADM_Africa_countries_AEA'      ,'shp'
			];
		}
		
		attribute<string> Name := inTable/Elements[((id(.)*NrAttributes)+0)[inTable]];
		attribute<string> Type := inTable/Elements[((id(.)*NrAttributes)+1)[inTable]];
		attribute<string> Path := inTable/Elements[((id(.)*NrAttributes)+2)[inTable]];
		attribute<string> Ext  := inTable/Elements[((id(.)*NrAttributes)+3)[inTable]];
		
		parameter<uint32> NrAttributes := 4;
	}
	
