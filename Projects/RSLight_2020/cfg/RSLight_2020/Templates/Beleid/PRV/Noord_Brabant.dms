container Noord_Brabant: url="%RSLDataDir%/Beleid/Ruimte/prv_2017/nb/Verordening ruimte Noord-Brabant Regels.mht"
{
	parameter<string> Prov: ['Noord_Brabant'];
	
	attribute<bool> Provincie (domain_grid) := = 'ProvincieK/per_domain_grid == ProvincieK/V/'+Prov;
	
	container Src := = '../Src/'+Prov;
	
	container woongebied_en_werk_bedrijventerrein
	{
		container Hard
		{
			attribute<bool> grondwaterbeschermingsgebied     (domain_grid) := Src/NL_IMRO_9930_VrNBrgecons_0717/water/grondwaterbeschermingsgebied/Bestand/Multi/Result;
			attribute<bool> Rivierbed                        (domain_grid) := Src/NL_IMRO_9930_VrNBrgecons_0717/water/Rivierbed/Bestand/Multi/Result;
			attribute<bool> waterwingebied                   (domain_grid) := Src/NL_IMRO_9930_VrNBrgecons_0717/water/waterwingebied/Bestand/Multi/Result;
			attribute<bool> Structuur_Groenblauwe_mantel     (domain_grid) := Src/NL_IMRO_9930_VrNBrgecons_0717/natuur_en_landschap/Structuur_Groenblauwe_mantel/Bestand/Multi/Result;
			attribute<bool> Structuur_Natuur_Netwerk_Brabant (domain_grid) := Src/NL_IMRO_9930_VrNBrgecons_0717/natuur_en_landschap/Structuur_Natuur_Netwerk_Brabant/Bestand/Multi/Result;
			
			attribute<bool> Totaal (domain_grid):= Max_elem
				(
					  grondwaterbeschermingsgebied
					, Rivierbed
					, waterwingebied
					, Structuur_Groenblauwe_mantel
					, Structuur_Natuur_Netwerk_Brabant
				);
		}
		
		container Middel
		{
			attribute<bool> Totaal (domain_grid) := const(false, domain_grid);
		}
		
		container Zacht
		{
			attribute<bool> Totaal (domain_grid) := const(false, domain_grid);
		}
	}
	
	container Glastuinbouw
	{
		container Hard
		{
			attribute<bool> Structuur_Groenblauwe_mantel (domain_grid) := Src/NL_IMRO_9930_VrNBrgecons_0717/natuur_en_landschap/Structuur_Groenblauwe_mantel/Bestand/Multi/Result;
			
			attribute<bool> Totaal (domain_grid):= Max_elem
				(
					  Structuur_Groenblauwe_mantel
				);
		}
		
		container Middel
		{
			attribute<bool> Totaal (domain_grid) := const(false, domain_grid);
		}
		
		container Zacht
		{
			attribute<bool> Totaal (domain_grid) := const(false, domain_grid);
		}
	}
	
	container Woongebied := Woongebied_en_werk_bedrijventerrein;
	container Bedrijventerrein := Woongebied_en_werk_bedrijventerrein;
}