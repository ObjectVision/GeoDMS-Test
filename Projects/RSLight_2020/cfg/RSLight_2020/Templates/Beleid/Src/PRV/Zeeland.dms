		parameter<string> OGRQuery_vlak         : = 'ogr2ogr -f ""ESRI Shapefile"" N:\SD\LUMOS\Beleid\Ruimte\prv_2017\ze\NL_IMRO_9929_vrpz2012_0001_Besluitvlak_P.shp  Y:\data\Leefomgeving\RS\brondata\BASIS2012\Beleid\Ruimte\Prv_2017\Besluitvlak_P.gml -where ""besluitgebied=""NL.IMRO.9929.vrpz2012-0001"" -skipfailures -overwrite';

