container Friesland : url="http://www.ruimtelijkeplannen.nl/web-roi/index/showManifest?organizationId=friesland&striVersion=STRI2008"{	container NL_IMRO_9921_PVR2014FryslanGC_GC01 : url="http://www.ruimtelijkeplannen.nl/web-roo/roo/bestemmingsplannen_p?planidn=NL.IMRO.9921.PVR2014FryslanGC-GC01"	{		//deze verordening lijkt grotendeels op de verordening NL.IMRO.9921.PVR2014Fryslan-VA01, alleen Kaart 3 lijkt anders van opzet				//PVR2014FryslanGC-GC01_Verordening Romte Fryslan 2014		//planstatus: geconsolideerd 2015-03-04		//identificatie: NL.IMRO.9921.PVR2014FryslanGC-GC01		//type plan: provinciale verordening		//naam overheid: Provincie Friesland		//ondergrond: grootschalige basiskaart (GBK) (2013-10-15)		//IMRO-versie: IMRO2012		//Kaarten (18)		//Kaart 1 - Begrenzing bestaand bebouwd gebied 		//Kaart 2 - Kernenstructuur en netwerkverbindingen 		//Kaart 3 - Natuur 		//Kaart 4 - Glastuinbouwlocaties Noordwest Fryslân 		//Kaart 5 - Reserveringszones versterking primaire waterkeringen 		//Kaart 6 - Havenkom Harlingen 		//Kaart 7 - Weidevogelgebieden 		//Kaart 8 - Bijzondere afwijkingen 		//Verbeelding behorende bij regels - Algemeen 		//Verbeelding behorende bij regels Artikel 1 - Bundeling 		//Verbeelding behorende bij regels Artikel 2 - Ruimtelijke kwaliteit 		//Verbeelding behorende bij regels Artikel 3 - Wonen 		//Verbeelding behorende bij regels Artikel 4 - Werken 		//Verbeelding behorende bij regels Artikel 5 - Recreatie en toerisme 		//Verbeelding behorende bij regels Artikel 6 - Landbouw 		//Verbeelding behorende bij regels Artikel 7 - Natuur 		//Verbeelding behorende bij regels Artikel 8 - Kustverdediging 		//Verbeelding behorende bij regels Artikel 9 - Duurzame energie 		parameter<string> Bestandsloc: = '%RSLDataDir%/Beleid/Ruimte/prv_2017/fr/NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P.shp';		parameter<string> OGRQuery: = 'ogr2ogr -f ""ESRI Shapefile"" N:\SD\LUMOS\Beleid\Ruimte\prv_2017\fr\NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P.shp  Y:\data\Leefomgeving\RS\brondata\BASIS2012\Beleid\Ruimte\Prv_2017\Besluitvlak_P.gml -where ""besluitgebied=""NL.IMRO.9921.PVR2014FryslanGC-GC01"" -skipfailures -overwrite';		container Kaart3 : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/fr/PVR2014FryslanGC-GC01_Verordening Romte Fryslan 2014.mht"		{			//Lagen:			//EHS beheergebied			//EHS overige natuur			//EHS water			//Natuur buiten de EHS				//TODOBAS welke aanroepen?				//5004							container EHS_beheergebied : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''EHS beheergebied'''				,''				,'=OGRQuery'			);//50885			container EHS_overige_natuur : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''EHS overige natuur'''				,''				,'=OGRQuery'			);//236540			container EHS_water : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''EHS water'''				,''				,'=OGRQuery'			);//292427// dit item is de som van:EHS_beheergebied,EHS_overige_natuur,EHS_water			container Ecologische_hoofdstructuur : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''Ecologische hoofdstructuur'''				,''				,'=OGRQuery'			);//7356			//"Natuur buiten de Ecologische hoofdstructuur" levert hetzelfde resultaat zit er kennelijk dubbel in			//Een ruimtelijk plan dat betrekking heeft op natuurgebieden buiten de ecologische hoofdstructuur, zoals aangegeven op de van deze verordening deel 			//uitmakende kaart Natuur, voorziet in een passende bestemming met gebruiksregels gericht op behoud, herstel of ontwikkeling van natuurwaarden.			container Natuur_buiten_de_EHS : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''Natuur buiten de EHS'''				,''				,'=OGRQuery'			);		}		container Kaart4 : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/fr/PVR2014FryslanGC-GC01_Verordening Romte Fryslan 2014.mht"		{			//Kaart 4 - Glastuinbouwlocaties Noordwest Fryslân. Lagen			//Glastuinbouw			//glastuinbouwlocaties Noordwest Fryslân			container glastuinbouwlocaties_Noordwest_Fryslan : = VergriddingT			(				'=Bestandsloc'				// let op dit bestand moet worden opgeslagen met 'Encoding', 'Encoding Type', 'UTF8-Encoding (w/o BOM)', ANSI gaat verkeerd 'â' niet te interpreteren				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''glastuinbouwlocaties Noordwest Fryslân'''				,'%RSLDataDir%/Beleid/Ruimte/prv_2017/fr/PVR2014FryslanGC-GC01_64_glastuinbouw.jpg'				,'=OGRQuery'			);		}		container Kaart5 : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/fr/PVR2014FryslanGC-GC01_Verordening Romte Fryslan 2014.mht"		{			//Kaart 5 - Reserveringszones versterking primaire waterkeringen. Lagen			//reserveringszones binnen aaneengesloten bebouwd gebied			//reserveringszones buiten aaneengesloten bebouwd gebied			container reserveringszones_binnen_aaneengesloten_bebouwd_gebied : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''reserveringszones binnen aaneengesloten bebouwd gebied'''				,''				,'=OGRQuery'			);			container reserveringszones_buiten_aaneengesloten_bebouwd_gebied : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''reserveringszones buiten aaneengesloten bebouwd gebied'''				,''				,'=OGRQuery'			);		}		container Kaart6 : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/fr/PVR2014FryslanGC-GC01_Verordening Romte Fryslan 2014.mht"		{			//Kaart 6 - Havenkom Harlingen. Lagen			//havenkom Harlingen 			container havenkom_Harlingen : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''havenkom Harlingen'''				,''				,'=OGRQuery'			);		}		container Kaart7 : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/fr/PVR2014FryslanGC-GC01_Verordening Romte Fryslan 2014.mht"		{			//Kaart 7 - Weidevogelgebieden. Lagen			//Weidevogelkansgebieden			//Weidevogelparels			container Weidevogelkansgebieden : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''Weidevogelkansgebieden'''				,''				,'=OGRQuery'			);			container Weidevogelparels : = VergriddingT			(				'=Bestandsloc'				,'SELECT * FROM NL_IMRO_9921_PVR2014FryslanGC_GC01_Besluitvlak_P WHERE naam =''Weidevogelparels'''				,''				,'=OGRQuery'			);		}	}}