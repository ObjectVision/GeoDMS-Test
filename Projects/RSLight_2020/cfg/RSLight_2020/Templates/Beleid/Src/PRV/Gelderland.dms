			//	  Verbod op ontgassen
			
			//niet aanwezig in vorige versie werd terugevallen op landelijk bestand
			container Stiltegebieden : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_9925_PVOmgverordeningGC_gc04_Besluitsubvlak_P WHERE naam =''Stiltegebieden'''
				,'http:\//www.ruimtelijkeplannen.nl/web-roo/transform/NL.IMRO.9925.PVOmgverordeningGC-gc04/pt_NL.IMRO.9925.PVOmgverordeningGC-gc04.xml#NL.IMRO.PT.s18e072ee-eba1-40da-a5a9-152e95155970'
