	container NL_IMRO_9925_PVOmgverordeningGC_gc04 : url="http://www.ruimtelijkeplannen.nl/web-roo/roo/bestemmingsplannen_p?planidn=NL.IMRO.9925.PVOmgverordeningGC-gc04"
	//http://www.ruimtelijkeplannen.nl/web-roo/roo/bestemmingsplannen_p?planidn=NL.IMRO.9925.PVOmgverordeningGC-gc05
	{
		//Omgevingsverordening Gelderland (juni 2017)
