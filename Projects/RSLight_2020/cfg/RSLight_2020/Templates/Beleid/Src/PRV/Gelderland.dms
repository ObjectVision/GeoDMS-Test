		parameter<string> Bestandsloc : = '%RSLDataDir%/Beleid/Ruimte/prv_2017/ge/NL_IMRO_9925_PVOmgverordeningGC_gc04_Besluitsubvlak_P.shp';
		parameter<string> OGRQuery    :    = 'ogr2ogr -f ""ESRI Shapefile"" N:\SD\LUMOS\Beleid\Ruimte\prv_2017\ge\NL_IMRO_9925_PVOmgverordeningGC_gc04_Besluitsubvlak_P.shp  Y:\data\Leefomgeving\RS\brondata\BASIS2012\Beleid\Ruimte\Prv_2017\Besluitsubvlak_P.gml -where ""besluitgebied=""NL.IMRO.9925.PVOmgverordeningGC-gc04"" -skipfailures -overwrite';

		container  Glastuinbouw : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/ge/Omgevingsverordening Gelderland (juni 2017).mht"
		{
			//Regels Glastuinbouw
			//	  Glastuinbouw extensiveringsgebied
			//	  Glastuinbouw in overige gebieden
			//	  Glastuinbouw regionaal cluster
			//	  Glastuinbouw zoekzone regionaal cluster
			//	x Glastuinbouwontwikkelingsgebied
			//	x Reserve glastuinbouwontwikkelingsgebied
			//	  Tijdelijk verbod hervestiging glastuinbouw
			//	  Tijdelijk verbod nieuwvestiging glastuinbouw
			//	  Tijdelijk verbod uitbreiding bestaande glastuinbouw
			
			//&&&&&Bart:Er zijn nog meer lagen die we zouden kunnen aanroepen (Glastuinbouw in overige gebieden), aansluitng wettekst en bestand niet helemaal duidelijk dan

			container Glastuinbouwontwikkelingsgebied : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_9925_PVOmgverordeningGC_gc04_Besluitsubvlak_P WHERE naam =''Glastuinbouwontwikkelingsgebied'''
				//,'http:\//www.ruimtelijkeplannen.nl/web-roo/transform/NL.IMRO.9925.PVOmgverordeningGC-gc04/pt_NL.IMRO.9925.PVOmgverordeningGC-gc04.xml#NL.IMRO.PT.sb3d1a202-c2e1-476f-bb7b-f3bc8dc0a852'
				,'%RSLDataDir%/Beleid/Ruimte/prv_2017/ge/PVOmgverordeningGC-gc05_24_glastuinbouw.jpg'
				,'=OGRQuery'
			);

			container Reserve_glastuinbouwontwikkelingsgebied : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_9925_PVOmgverordeningGC_gc04_Besluitsubvlak_P WHERE naam =''Reserve glastuinbouwontwikkelingsgebied'''
				//,'http:\//www.ruimtelijkeplannen.nl/web-roo/transform/NL.IMRO.9925.PVOmgverordeningGC-gc04/pt_NL.IMRO.9925.PVOmgverordeningGC-gc04.xml#NL.IMRO.PT.sb3d1a202-c2e1-476f-bb7b-f3bc8dc0a852'
				,'%RSLDataDir%/Beleid/Ruimte/prv_2017/ge/PVOmgverordeningGC-gc05_24_glastuinbouw.jpg'
				,'=OGRQuery'
			);

			container Glastuinbouw_regionaal_cluster : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_9925_PVOmgverordeningGC_gc04_Besluitsubvlak_P WHERE naam =''Glastuinbouw regionaal cluster'''
				//,'http:\//www.ruimtelijkeplannen.nl/web-roo/transform/NL.IMRO.9925.PVOmgverordeningGC-gc04/pt_NL.IMRO.9925.PVOmgverordeningGC-gc04.xml#NL.IMRO.PT.sb3d1a202-c2e1-476f-bb7b-f3bc8dc0a852'
				,'%RSLDataDir%/Beleid/Ruimte/prv_2017/ge/PVOmgverordeningGC-gc05_24_glastuinbouw.jpg'
				,'=OGRQuery'
			);
		}

		container  Natuur : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/ge/Omgevingsverordening Gelderland (juni 2017).mht"
		{
			//Regels Natuur
			//	  Beschermingszone natte landnatuur
			//	  GNN natuurbegraven en kleinschalige recreatie onder bijzondere voorwaarden mogelijk
			//	  GNN natuurbegraven en kleinschalige recreatie onder voorwaarden mogelijk
			//	  GNN windturbines onder voorwaarden mogelijk
			//	x Gelders natuurnetwerk
			//	  Groene ontwikkelingszone

			//let op grote wijziging!
			// niet gelijk aan vorige versie: 142050 (was 214881)    ///StudieGebieden/NlBaseYear/BronData/Beleid/Ruimte/PRV2014/PRV_GE/ehs/ehs_PRV_GE_ehs
			container Gelders_natuurnetwerk : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_9925_PVOmgverordeningGC_gc04_Besluitsubvlak_P WHERE naam =''Gelders natuurnetwerk'''
				,'http:\//www.ruimtelijkeplannen.nl/web-roo/transform/NL.IMRO.9925.PVOmgverordeningGC-gc04/pt_NL.IMRO.9925.PVOmgverordeningGC-gc04.xml#NL.IMRO.PT.s650c9327-2c18-4d45-901c-01149ccde045'
