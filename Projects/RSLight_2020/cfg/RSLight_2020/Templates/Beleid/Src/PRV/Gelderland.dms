// 				,'=OGRQuery'
// 			);
		}
		
		//Rienk Kuiper december 2017: WAARDEVOL OPEN GEBIED RESTRICTIEF VOOR WONEN EN WERKEN
		container  Landschap : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/ge/Omgevingsverordening Gelderland (juni 2017).mht"
		{
			//Lagen:
			//   Nationaal landschap buiten GNN, GO en NHW
			// x Nieuwe Hollandse Waterlinie
			//   Romeinse Limes
			//   Waardevol open gebied

			container Nieuwe_Hollandse_Waterlinie : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_9925_PVOmgverordeningGC_gc04_Besluitsubvlak_P WHERE naam =''Nieuwe Hollandse Waterlinie'''
				,'http:\//www.ruimtelijkeplannen.nl/web-roo/transform/NL.IMRO.9925.PVOmgverordeningGC-gc04/pt_NL.IMRO.9925.PVOmgverordeningGC-gc04.xml#NL.IMRO.PT.sa9b7feac-62d9-4923-b434-0bab1f8986bf'
