			container Weidevogelleefgebied : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_9927_PRVPNHCONSOLID_0103_Besluitvlak_P WHERE naam =''Weidevogelleefgebied'''
				,'http:\//www.ruimtelijkeplannen.nl/web-roo/transform/NL.IMRO.9927.PRVPNHCONSOLID-0103/pt_NL.IMRO.9927.PRVPNHCONSOLID-0103.xml#NL.IMRO.PT.sc3579b7d-a416-4b47-a50c-c39e9920906d'
				,'=OGRQuery'
			);
