		container  UNESCO : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/nh/Provinciale Ruimtelijke Verordening (geconsolideerde versie; treed in werking vanaf 1-maart-2017 ).mht"
		{
			//	  UNESCO
			//	x Beemster
			//	x Grachtengordel Amsterdam
			//	x Nieuwe Hollandse Waterlinie (toekomstig)
			//	x Stelling van Amsterdam

			// niet gelijk aan vorige versie: 28948 (was 29378)    ///StudieGebieden/NlBaseYear/BronData/Beleid/Ruimte/PRV2014/PRV_NH/Kaart5a_unesco
			container Beemster_Grachtengordel_Amsterdam_Stelling_van_Amsterdam_NHW : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_9927_PRVPNHCONSOLID_0103_Besluitvlak_P WHERE naam =''Beemster'' OR naam =''Grachtengordel Amsterdam'' OR naam =''Stelling van Amsterdam'' OR naam =''Nieuwe Hollandse Waterlinie (toekomstig)'''
				,'http:\//www.ruimtelijkeplannen.nl/web-roo/transform/NL.IMRO.9927.PRVPNHCONSOLID-0103/pt_NL.IMRO.9927.PRVPNHCONSOLID-0103.xml#NL.IMRO.PT.sf5308a32-1a31-4025-93c8-8c3ef83daa5f'
