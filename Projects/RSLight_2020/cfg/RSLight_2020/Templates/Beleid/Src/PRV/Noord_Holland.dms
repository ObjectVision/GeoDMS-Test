		container  Bufferzones : url="%RSLDataDir%/Beleid/Ruimte/prv_2017/nh/Provinciale Ruimtelijke Verordening (geconsolideerde versie; treed in werking vanaf 1-maart-2017 ).mht"
		{
			//	  Bufferzones
			//	x Bufferzone

			// niet gelijk aan vorige versie: 35286 (was 81103)    //StudieGebieden/NlBaseYear/BronData/Beleid/Ruimte/PRV2014/PRV_NH/Kaart5b_bufferzones/Kaart5b_bufferzones
			container Bufferzone : = VergriddingT
