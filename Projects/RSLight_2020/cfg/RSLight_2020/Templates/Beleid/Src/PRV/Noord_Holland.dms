			//	x Regionale waterkering
			//	  Strandzonering (met mogelijkheden voor jaarrond strandpaviljoens, jaarrond sportpaviljoens en jaarrond reddingsbrigades)

			// vergelijking met vorige versie niet echt mogelijk
			container Regionale_waterkering : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_9927_PRVPNHCONSOLID_0103_Besluitvlak_P WHERE naam =''Regionale waterkering'''
				,'http:\//www.ruimtelijkeplannen.nl/web-roo/transform/NL.IMRO.9927.PRVPNHCONSOLID-0103/pt_NL.IMRO.9927.PRVPNHCONSOLID-0103.xml#NL.IMRO.PT.s3cffc2a2-e1cc-48da-9c28-94b86715b461'
