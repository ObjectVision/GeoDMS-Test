		parameter<string> OGRQuery: = 'ogr2ogr -f ""ESRI Shapefile"" N:\SD\LUMOS\Beleid\Ruimte\ruimtelijkeplannen\Amvb_2017\NL_IMRO_0000_IMamGCBarro_50211_Besluitsubvlak_A.shp  Y:\data\Leefomgeving\RS\brondata\BASIS2012\Beleid\Ruimte\Prv_2017\Besluitsubvlak_A.gml -where ""besluitgebied=""NL.IMRO.0000.IMamGCBarro-5021"" -skipfailures -overwrite';

		container Kaart2 : url="%RSLDataDir%/Beleid/Ruimte/ruimtelijkeplannen/Amvb_2017/IMamGCBarro-5021_Besluit algemene regels ruimtelijke ordening Besluit algemene regels ruimtelijke ordening.mht"
		{
			//Project Mainportontwikkeling Rotterdam.Lagen:
			//gebied voor compensatie van de effecten van de landaanwinning op open droog duin
			//gebied voor compensatie van het verlies aan zeenatuur als gevolg van de landaanwinning
			//landaanwinningsgebied
			//openbaar toegankelijk natuur- en recreatiegebied Midden IJsselmonde
			//openbaar toegankelijk natuur- en recreatiegebied Schiebroekse- en Zuidpolder
			//openbaar toegankelijk natuur- en recreatiegebied Schiezone

			container openbaar_toegankelijk_natuur_en_recreatiegebied_Midden_IJsselmonde : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMamGCBarro_50211_Besluitsubvlak_A WHERE naam =''openbaar toegankelijk natuur- en recreatiegebied Midden IJsselmonde'''
				,''
