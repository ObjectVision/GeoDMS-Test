	container  NL_IMRO_0000_IMmrGCRarro_5030 : url="http://www.ruimtelijkeplannen.nl/web-roo/roo/bestemmingsplannen_p?planidn=NL.IMRO.0000.IMmrGCRarro-5030"
	{
		//Regeling algemene regels ruimtelijke ordening (ministeriele regeling) (geconsolideerde versie)
		//planstatus: geconsolideerd 2016-07-01
		//identificatie: NL.IMRO.0000.IMmrGCRarro-5030
		//type plan: regeling
		//naam overheid: Ministerie van Infrastructuur en Milieu
		//ondergrond: basisregistratie topografie (BRT) (2014-01-09)
		//IMRO-versie: IMRO2012

		//Kaarten (13)
		//algemeen 
		//militaire terreinen 
		//onveilige gebieden buiten militair terrein 
		//militaire luchtvaartterreinen 
		//zend- en ontvangstinstallaties buiten militair luchtvaartterrein 
		//radarstations 
		//laagvliegroutes voor jacht- en transportvliegtuigen 
		//munitieopslagplaatsen 
		//civiele inrichtingen voor activiteiten met explosieven 
		//reserveringsgebieden weg 
		//nieuwe reserveringsgebieden weg en spoor 
		//militaire terreinen geen EHS 
		//voorkeurstracés buisleidingen

		parameter<string> Bestandsloc: = '%RSLDataDir%/Beleid/Ruimte/ruimtelijkeplannen/Amvb_2017/NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A.shp';
		parameter<string> OGRQuery: = 'ogr2ogr -f ""ESRI Shapefile"" N:\SD\LUMOS\Beleid\Ruimte\ruimtelijkeplannen\Amvb_2017\NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A.shp  Y:\data\Leefomgeving\RS\brondata\BASIS2012\Beleid\Ruimte\Prv_2017\Besluitsubvlak_A.gml -where  "OGR_GEOMETRY=''Point'' && besluitgebied=""NL.IMRO.0000.IMmrGCRarro-5030"" -skipfailures -overwrite';

		container Kaart1 : url="%RSLDataDir%/Beleid/Ruimte/ruimtelijkeplannen/Amvb_2017/IMmrGCRarro-5030_Regeling algemene regels ruimtelijke ordening Besluit.mht"
		{
			container militair_terrein : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,16) =''militair terrein'''
				,''
				'=OGRQuery'
			);

			container militair_luchtvaartterrein : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,26) =''militair luchtvaartterrein'''
				,''
				'=OGRQuery'
			);
		}
	
		container Kaart8 : url="%RSLDataDir%/Beleid/Ruimte/ruimtelijkeplannen/Amvb_2017/IMmrGCRarro-5030_Regeling algemene regels ruimtelijke ordening Besluit.mht"
		{

			container A_zone_munitieopslagplaats : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,8) =''A-zone m'''
				,''
				'=OGRQuery'
			);

			container B_zone_munitieopslagplaats : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,8) =''B-zone m'''
				,''
				'=OGRQuery'
			);

			container C_zone_munitieopslagplaats : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,8) =''C-zone m'''
				,''
				'=OGRQuery'
			);
		}

		container Kaart9 : url="%RSLDataDir%/Beleid/Ruimte/ruimtelijkeplannen/Amvb_2017/IMmrGCRarro-5030_Regeling algemene regels ruimtelijke ordening Besluit.mht"
		{
			//civiele inrichtingen voor activiteiten met explosieven. Lagen
			//civiele inrichting voor activiteiten met explosieven complex TNO Rijswijk
			//civiele inrichting voor activiteiten met explosieven complex TNO Ypenburg
			//civiele inrichting voor activiteiten met explosieven complex Ulicoten

			container A_zone_civiele_inrichting_voor_activiteiten_met_explosieven  : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,8) =''A-zone c'''
				,''
				'=OGRQuery'
			);

			container B_zone_civiele_inrichting_voor_activiteiten_met_explosieven : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,8) =''B-zone c'''
				,''
				'=OGRQuery'
			);

			container C_zone_civiele_inrichting_voor_activiteiten_met_explosieven : = VergriddingT
			(
				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,8) =''C-zone c'''
				,''
				'=OGRQuery'
			);
		}

		container Kaart13 : url="%RSLDataDir%/Beleid/Ruimte/ruimtelijkeplannen/Amvb_2017/IMmrGCRarro-5030_Regeling algemene regels ruimtelijke ordening Besluit.mht"
		{
			//voorkeurstracés buisleidingen
			//Hoofdverbindingen Noord-Nederland
			//Hoofdverbindingen Rijnmond - Zeeland/België
			//tracé door Gelderland en Zuid-Holland
			//tracé door Hoekse Waard en Noord-Brabant
			//tracé door Noord-Brabant en Limburg
			//tracé door Noord-Holland en Zuid-Holland
			//tracé door Voorne-Putten
			//tracé door oostelijk Nederland
			//tracés door Limburg
			//zoekgebied buisleidingen

			//&&&&&Bart: vergridding van smalle langwerpige polygonen lijkt in dit geval tot onwenselijke resultaten (Zie Hoofdverbindingen Noord-Nederland) - (vergridden buiten GeoDMS). Er lijkt geen GeoDMS tegenhanger te zijn
			//van vergridden in ArcGIS mbv lijnelement (inbranden)
			
			container voorkeurstraces_buisleidingen : = VergriddingT
			(			
				'=Bestandsloc'
				//https://www.infomil.nl/onderwerpen/veiligheid/buisleidingen/
				//In het Barro is aangegeven dat aan weerszijden van de voorkeurstracés een zoekgebied geldt van 250 meter. Daarbinnen kan de gemeente de exacte ligging van het buisleidingen tracé bepalen. 
				//Mits het tracé aansluit op het voorkeurstracé bij de naastliggende gemeenten en het tracé dezelfde breedte heeft als de breedte van het grootste deel van het tracé.
				//,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,10) =''tracé door'' OR naam= ''Hoofdverbindingen Noord-Nederland'' OR naam= ''Hoofdverbindingen Rijnmond - Zeeland/België'' OR naam= ''zoekgebied buisleidingen'''
				,'SELECT * FROM NL_IMRO_0000_IMmrGCRarro_5030_Besluitsubvlak_A WHERE SUBSTR(naam,1,10) =''tracé door'' OR naam= ''Hoofdverbindingen Noord-Nederland'' OR naam= ''Hoofdverbindingen Rijnmond - Zeeland/België'''
				,''
				'=OGRQuery'
			);
		}
	}
}