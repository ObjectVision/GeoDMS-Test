				'=Bestandsloc'
				,'SELECT * FROM NL_IMRO_0000_IMamGCBarro_50211_Besluitsubvlak_A WHERE naam =''openbaar toegankelijk natuur- en recreatiegebied Schiebroekse- en Zuidpolder'''
				,''
				'=OGRQuery'
			);

			container openbaar_toegankelijk_natuur_en_recreatiegebied_Schiezone : = VergriddingT
			(
				'=Bestandsloc'
