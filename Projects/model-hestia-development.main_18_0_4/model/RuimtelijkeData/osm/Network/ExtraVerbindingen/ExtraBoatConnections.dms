		unit<uint32> link : nrofrows = 6
		,	Source     = "op basis van AND Netwerk"
		{
			attribute<rdc_meter>        geometry (arc)     := points2sequence(pointset/point, pointset/sequence, pointset/ordinal);
			attribute<rdc_meter>        firstnode          := first_point(geometry);
			attribute<rdc_meter>        lastnode           := last_point(geometry);
		}
		unit<uint32> nodes := union_unit(link, link)
		{
			attribute<rdc_meter>        geometry           := union_data(.,link/firstnode, link/lastnode), Label = "Nodes van begin en eind paden die gekoppeld worden";
		}
	}
	
	unit<uint32> link := union_unit(Nederland/link)
	{
		attribute<rdc_meter>                   geometry (arc)     := union_data(., Nederland/link/geometry);
		attribute<OSM/wegtype> wegtype            := const(OSM/wegtype/V/ferry, .);
		attribute<bool>                        isPartOfCarNetwork := OSM/wegtype/IsPartOfCarNetwork[wegtype];
		attribute<km_hr>                       Maxspeed           := const(ModelParameters/netwerk/Ferry_Speed, .);
	}
	unit<uint32> nodes := union_unit(Nederland/nodes)
	{
		attribute<rdc_meter>        geometry           := union_data(., Nederland/nodes/geometry);
	}
