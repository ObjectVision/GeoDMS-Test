REM ============================================================
REM MACHINE-SPECIFIC paths. The live file SetRegressionTestsDir.bat
REM is git-ignored. On first use it is auto-created from this
REM .example by SetRelativePaths.bat; edit the copy to match THIS
REM machine. Only this .example is tracked - never commit the copy.
REM ============================================================

REM Root of the regression source data (prj_snapshots, RSL, Hestia, ...)
Set RegressionTestsSourceDataDir=F:\SourceData\RegressionTests

REM Root for alternate / shared source data (RSOpen, ...)
Set RegressionTestsAltSourceDataDir=F:\SourceData

REM Local (machine-local, fast) scratch / results dir
Set LocalDataDir=C:\LocalData
